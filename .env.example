TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

OPENAI_API_KEY=

# Private planning model (Responses API + Structured Outputs + web search).
# Compatible choices: gpt-5.4-mini, gpt-5.4, gpt-5.6
OPENAI_MODEL=gpt-5.4-mini

# Live speech-to-speech model (Realtime API).
# Compatible choices: gpt-realtime-2.1-mini, gpt-realtime-2.1
# GPT-5.4 and GPT-5.6 text models are not Realtime audio models.
RELAY_REALTIME_MODEL=gpt-realtime-2.1-mini

# Representative speech-to-text model inside the live Realtime session.
# Compatible choices: gpt-4o-mini-transcribe (lower cost), gpt-4o-transcribe (higher accuracy)
RELAY_TRANSCRIPTION_MODEL=gpt-4o-mini-transcribe
